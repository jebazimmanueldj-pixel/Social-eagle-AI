# ─────────────────────────────────────────────────────────────
#  AML Data Warehouse — Frontend environment variables (example)
#  Copy this file to .env and edit as needed.
#  Without this file Vite proxies /api to http://localhost:8080
#  which is what you want for local development.
# ─────────────────────────────────────────────────────────────

# Override the API base URL only if backend is on a different host/port.
# Leave blank for local dev (Vite proxy handles it automatically).
# VITE_API_BASE=http://localhost:8080/api
