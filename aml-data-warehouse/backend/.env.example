# ─────────────────────────────────────────────────────────────
#  AML Data Warehouse — Backend environment variables (example)
#  Copy this file to .env and edit as needed.
#  The app works out-of-the-box WITHOUT setting any of these —
#  the defaults in application.yml are used automatically.
# ─────────────────────────────────────────────────────────────

# JWT signing secret (min 32 chars for HS256)
JWT_SECRET=AmlDataWarehouseSecretKey2024!!SuperSecureAndLongEnoughForHS256Algorithm

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# MongoDB URI (only needed when running with --spring.profiles.active=postgres)
MONGO_URI=mongodb://aml_user:aml_pass@localhost:27017/aml_dw?authSource=admin

# PostgreSQL (only needed with --spring.profiles.active=postgres)
DB_URL=jdbc:postgresql://localhost:5432/aml_dw
DB_USER=aml_user
DB_PASS=aml_pass
